modules = ["nodejs-20", "web"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
PORT = "3000"
API_BASE_URL = "http://localhost:3000"
JWT_ACCESS_TTL = "2h"
JWT_REFRESH_TTL = "14d"
KMS_KEY_ID = "local"
OTP_DRY_RUN = "1"
ADMIN_REQUIRE_2FA = "false"
TOTP_ISSUER = "Nuxia2"
WITHHOLDING_BPS = "330"
WITHDRAW_COOLDOWN_DAYS = "30"
HOLD_DAYS = "7"
MIN_PAYOUT_KRW = "10000"
SMS_PROVIDER = "solapi"
SMTP_FROM = "no-reply@nuxia2.kr"
SMTP_PORT = "587"

[userenv.development]
NODE_ENV = "development"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash -c 'cd apps/web && pnpm install && pnpm dev'"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "cd apps/web && pnpm start"]
build = ["bash", "-c", "cd apps/web && pnpm install && pnpm build"]
