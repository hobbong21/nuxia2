# Docker Compose 전용 환경 변수 (실제 파일명: .env, docker-compose가 자동 로드)
# 사용법: cp .env.docker.example .env

POSTGRES_DB=nuxia2
POSTGRES_USER=nuxia2
POSTGRES_PASSWORD=nuxia2_dev
POSTGRES_PORT=5432

REDIS_PORT=6379

# --- v0.4 admin / metrics / 2FA / FE mock ---
ADMIN_API_KEY=dev_admin_api_key
METRICS_INTERNAL_SECRET=dev_metrics_secret
TOTP_ISSUER=Nuxia2-Dev
NEXT_PUBLIC_USE_MOCK=0

# --- v0.5 OTP backup + 2FA enforcement ---
OTP_DRY_RUN=1
ADMIN_REQUIRE_2FA=false
SMS_PROVIDER=solapi
SMTP_FROM=no-reply@nuxia2.kr

# apps/api/.env.local은 별도로 작성 — apps/api/.env.example 참고
# apps/web/.env.local은 선택 — 기본값으로 http://localhost:4000 사용
