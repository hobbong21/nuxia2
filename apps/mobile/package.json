{
  "name": "@nuxia2/mobile",
  "version": "0.0.1",
  "private": true,
  "description": "Capacitor wrapper for Nuxia web app (iOS / Android)",
  "scripts": {
    "build:web": "pnpm --filter @nuxia2/web run build:hybrid",
    "sync": "pnpm run build:web && cap sync",
    "cap:add:ios": "cap add ios",
    "cap:add:android": "cap add android",
    "cap:open:ios": "cap open ios",
    "cap:open:android": "cap open android",
    "cap:run:ios": "cap run ios",
    "cap:run:android": "cap run android"
  },
  "dependencies": {
    "@capacitor/app": "^6.0.0",
    "@capacitor/android": "^6.1.2",
    "@capacitor/core": "^6.1.2",
    "@capacitor/ios": "^6.1.2",
    "@capacitor/keyboard": "^6.0.2",
    "@capacitor/preferences": "^6.0.2",
    "@capacitor/share": "^6.0.2",
    "@capacitor/status-bar": "^6.0.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.1.2",
    "typescript": "^5.5.4"
  }
}
