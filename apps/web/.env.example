# @nuxia2/web — Next.js 14 App Router
# 복사: cp apps/web/.env.example apps/web/.env.local
# 로컬에서만 사용 (git 제외됨). NEXT_PUBLIC_* 는 빌드 타임 주입됨.

# ---------- Backend 연결 ----------

# API 베이스 URL (dev: http://localhost:4000, prod: https://api.nuxia2.kr)
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# ---------- 관리자 UI ----------

# 1로 설정 시 admin-client가 mock 데이터 반환 (BE 미기동 시 UI 확인용)
# 기본값 미설정(0) = 실 API 호출
NEXT_PUBLIC_USE_MOCK=0

# 관리자 페이지 가드 우회 (NODE_ENV=production에서는 무시됨)
# 1로 설정 시 role 쿠키 없이도 /admin/* 접근 가능 (개발 편의)
NEXT_PUBLIC_ADMIN_BYPASS=0

# ---------- 포트원(PortOne V2) ----------

# 포트원 콘솔의 Store ID
NEXT_PUBLIC_PORTONE_STORE_ID=store-test-xxx

# 결제 수단별 channel key (PaymentMethodPicker에서 사용)
# 포트원 콘솔에서 각 수단(카드/계좌이체/간편결제)별로 채널 키 발급
NEXT_PUBLIC_PORTONE_CARD_CHANNEL_KEY=channel-key-card
NEXT_PUBLIC_PORTONE_TRANSFER_CHANNEL_KEY=channel-key-transfer
NEXT_PUBLIC_PORTONE_EASYPAY_CHANNEL_KEY=channel-key-easypay

# 본인인증 채널 키
NEXT_PUBLIC_PORTONE_IV_CHANNEL_KEY=channel-key-identity

# ---------- 기타 ----------

# Capacitor 하이브리드앱 빌드 (static export). 웹 배포에는 미설정
# HYBRID_BUILD=1
