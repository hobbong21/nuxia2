// Nuxia Commerce × 3-Generation Referral - Prisma Schema
// Policies enforced: T1 원천징수 3.3% · T2 유보후환불 역정산생략 · T3 쿠폰차감후 기준 ·
//                   T4 포인트 현금성 · T5 탈퇴쿨다운 30일 · T6 임직원 참여불가 ·
//                   T7 미성년 수동해제 · T8 결손세대 플랫폼 귀속

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ============================================================================
// Enums
// ============================================================================

enum UserRole {
  CUSTOMER
  STAFF         // T6: 임직원 - referrer/referee 양쪽 불가
  STAFF_FAMILY  // T6: 임직원 직계가족 - 동일 제약
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
  WITHDRAWN      // T5: 탈퇴 (30일 쿨다운)
  UNDER_REVIEW   // A3: 다중계정 의심
  MINOR_HOLD     // T7: 미성년 - payoutEligibility=false 연동
}

enum ProductStatus {
  // QA P1-05: shared-types ProductStatusSchema와 통일 (DRAFT/ACTIVE/SOLD_OUT/HIDDEN/ARCHIVED)
  DRAFT
  ACTIVE
  SOLD_OUT
  HIDDEN
  ARCHIVED
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  PREPARING
  SHIPPED
  DELIVERED
  CONFIRMED
  // QA P0-08: shared-types와 스펠링 통일 (double L)
  CANCELLED
  REFUNDED
  PARTIAL_REFUNDED
  HOLD
}

enum LedgerType {
  EARN
  REVERT
}

enum LedgerStatus {
  PENDING
  CONFIRMED
  SUSPENDED_FOR_REVIEW
  PAID
  CLAWBACK_REQUESTED
}

enum PayoutStatus {
  PENDING
  WITHHELD
  PAID
  FAILED
  CLAWBACK_REQUESTED
}

enum AbuseKind {
  SELF_REFERRAL
  ANCESTOR_SELF_REFERRAL
  CIRCULAR
  DUPLICATE_CI
  STAFF_REFERRAL
  WITHDRAW_REJOIN_COOLDOWN
  RATE_LIMIT
  BOT_PATTERN
  SWAP
  MULTI_ACCOUNT
}

enum AbuseAction {
  LOGGED
  BLOCKED
  HELD
  SUSPENDED
}

// ============================================================================
// Users & Auth
// ============================================================================

model User {
  id                 String     @id @default(cuid())
  email              String     @unique
  passwordHash       String?
  nickname           String
  // 본인인증 연계정보 (앱 레벨 AES-256-GCM 암호화 저장).
  // 유일성 검사는 ciHash(결정적 HMAC)로 수행.
  ci                 String?    // ciphertext
  ciHash             String?    @unique
  dateOfBirth        DateTime?
  phoneNumber        String?    // 암호화

  role               UserRole   @default(CUSTOMER)
  status             UserStatus @default(ACTIVE)
  payoutEligibility  Boolean    @default(true)   // T7 미성년: false. 성년 도달로 자동 true 금지.

  referralCode       String     @unique
  referrerId         String?
  referrer           User?      @relation("Referral", fields: [referrerId], references: [id])
  referees           User[]     @relation("Referral")
  // 3세대 ancestor 캐시 ([1대, 2대, 3대]) - 가입 시 1회 계산
  ancestorPath       String[]

  withdrawnAt        DateTime?
  lastLoginAt        DateTime?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  // v0.4 M5 — 2FA (TOTP). totpSecret 은 AES-256-GCM 암호화 저장.
  totpSecret         String?
  totpEnabled        Boolean    @default(false)
  totpEnabledAt      DateTime?

  // v0.5 M3 — OTP 백업 (SMS/이메일). E.164 형식으로 저장, 앱 레벨 암호화 권장.
  phoneE164          String?

  orders             Order[]
  ledgers            ReferralLedger[] @relation("Beneficiary")
  payouts            Payout[]
  bankAccount        BankAccount?
  abuseLogs          AbuseLog[]       @relation("PrimaryUser")
  auditLogs          AuditLog[]       @relation("Actor")
  sessions           Session[]
  otpChallenges      OtpChallenge[]

  @@index([referrerId])
  @@index([status])
  @@index([role])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshHash  String
  userAgent    String?
  ipHash       String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  revokedAt    DateTime?

  @@index([userId])
  @@index([expiresAt])
}

model BankAccount {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bankCode       String
  accountNumber  String   // 암호화
  accountNumberMasked String
  accountHolder  String
  verifiedAt     DateTime?
  createdAt      DateTime @default(now())
}

// ============================================================================
// Products
// ============================================================================

// QA P1-05: shared-types ProductSchema와 1:1 정렬
// 마이그레이션 노트 (배포 시 `prisma migrate dev`):
//   - sku → slug 로 리네임 (unique 유지)
//   - priceKrw → salePriceKrw 로 리네임 (기존 값 복사)
//   - listPriceKrw 신규 (default = salePriceKrw), discountPct 신규 (default 0)
//   - brandName, avgRating, reviewCount, referralPreviewBps 신규
//   - ON_SALE → ACTIVE 로 데이터 이행 (enum 변경과 함께)
model Product {
  id                 String         @id @default(cuid())
  slug               String         @unique
  name               String
  description        String         @default("")
  /// 정가 (KRW)
  listPriceKrw       BigInt
  /// 할인 후 판매가 (KRW)
  salePriceKrw       BigInt
  /// 0~100 정수 할인율. listPrice / salePrice 로 계산 가능하나 캐시 컬럼
  discountPct        Int            @default(0)
  brandName          String?
  stock              Int            @default(0)
  category           String?
  images             String[]
  /// 레퍼럴 적립률 프리뷰용 (bps. 2500 = 25% 합계 표시 등)
  referralPreviewBps Int?           @default(2500)
  avgRating          Float          @default(0)
  reviewCount        Int            @default(0)
  status             ProductStatus  @default(ACTIVE)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  orderItems  OrderItem[]
  cartItems   CartItem[]

  @@index([status])
  @@index([category])
}

// ============================================================================
// Cart
// ============================================================================

model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique
  items     CartItem[]
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id        String  @id @default(cuid())
  cartId    String
  cart      Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int

  @@unique([cartId, productId])
}

// ============================================================================
// Orders
// ============================================================================

model Order {
  id                String        @id @default(cuid())
  userId            String
  user              User          @relation(fields: [userId], references: [id])
  items             OrderItem[]

  // 금액 (원 단위 BigInt) - T3: 쿠폰 차감 후 실결제 금액 기준
  totalAmountKrw    BigInt        // 레퍼럴 기준 금액 (T4: 포인트 포함=현금성)
  // QA P0-03 후속: shared-types OrderSchema 와 매칭
  subtotalAmountKrw   BigInt      @default(0)  // 상품 합계 (쿠폰·포인트 적용 전)
  couponDiscountKrw   BigInt      @default(0)  // 쿠폰 할인액
  pointUsedKrw      BigInt        @default(0)
  discountKrw       BigInt        @default(0)  // legacy; 호환용
  shippingFeeKrw    BigInt        @default(0)  // (구 shippingKrw)

  status            OrderStatus   @default(PENDING_PAYMENT)
  paymentId         String?       @unique
  paymentMethod     String?

  confirmedAt       DateTime?
  canceledAt        DateTime?
  refundedAt        DateTime?
  refundedAmountKrw BigInt        @default(0)

  shippingAddress   Json?

  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  ledgers           ReferralLedger[]
  refunds           Refund[]

  @@index([userId, status])
  @@index([createdAt])
  @@index([status])
}

model OrderItem {
  id                  String   @id @default(cuid())
  orderId             String
  order               Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId           String
  product             Product  @relation(fields: [productId], references: [id])
  productNameSnapshot String
  // QA P0-03/P1-05 후속: shared-types OrderItemSchema 와 shape 일치
  imageUrlSnapshot    String?
  optionSummary       String?
  unitPriceKrw        BigInt
  quantity            Int
  // 라인 소계 캐시 (= unitPriceKrw × quantity). 저장 시 계산
  lineAmountKrw       BigInt   @default(0)
  refundedQuantity    Int      @default(0)

  @@index([orderId])
}

model Refund {
  id            String   @id @default(cuid())
  orderId       String
  order         Order    @relation(fields: [orderId], references: [id])
  amountKrw     BigInt
  reason        String
  isPartial     Boolean  @default(false)
  ratioBps      Int      // 10000 = 100%
  lateRefund    Boolean  @default(false)  // T2: 유보 후 환불 (역정산 생략)
  createdAt     DateTime @default(now())
  processedAt   DateTime?

  @@index([orderId])
}

// ============================================================================
// Referral
// ============================================================================

model ReferralLedger {
  id                  String        @id @default(cuid())
  orderId             String
  order               Order         @relation(fields: [orderId], references: [id])
  beneficiaryUserId   String
  beneficiary         User          @relation("Beneficiary", fields: [beneficiaryUserId], references: [id])
  generation          Int           // 1|2|3
  rateBps             Int           // 300 | 500 | 1700
  amountKrw           BigInt        // EARN: +, REVERT: -
  type                LedgerType
  status              LedgerStatus  @default(PENDING)
  reason              String?
  createdAt           DateTime      @default(now())

  @@unique([orderId, beneficiaryUserId, generation, type])
  @@index([beneficiaryUserId, createdAt])
  @@index([status])
}

// ============================================================================
// Payout & Tax config (T1)
// ============================================================================

model Payout {
  id                 String       @id @default(cuid())
  userId             String
  user               User         @relation(fields: [userId], references: [id])
  periodStart        DateTime     @db.Date
  periodEnd          DateTime     @db.Date
  amountGrossKrw     BigInt
  amountTaxKrw       BigInt       @default(0)   // T1: 원천징수
  amountNetKrw       BigInt
  taxConfigId        String?
  taxConfig          PayoutTaxConfig? @relation(fields: [taxConfigId], references: [id])
  status             PayoutStatus @default(PENDING)
  bankMaskedAccount  String?
  processedAt        DateTime?
  failedReason       String?
  createdAt          DateTime     @default(now())

  @@unique([userId, periodStart, periodEnd])
  @@index([status])
}

// T1: 원천징수 설정 - config 대체 안전장치
model PayoutTaxConfig {
  id              String   @id @default(cuid())
  effectiveFrom   DateTime
  withholdingBps  Int      // 330 = 3.30%
  kind            String   // 'BUSINESS_INCOME' | 'OTHER_INCOME'
  note            String?
  createdAt       DateTime @default(now())

  payouts         Payout[]

  @@index([effectiveFrom])
}

// ============================================================================
// Abuse & Audit
// ============================================================================

model AbuseLog {
  id               String      @id @default(cuid())
  kind             AbuseKind
  severity         Int         @default(3)  // 1~5
  primaryUserId    String?
  primaryUser      User?       @relation("PrimaryUser", fields: [primaryUserId], references: [id])
  relatedUserIds   String[]
  relatedOrderIds  String[]
  evidence         Json
  action           AbuseAction @default(LOGGED)
  detectedAt       DateTime    @default(now())

  @@index([kind, detectedAt])
  @@index([primaryUserId])
}

model AuditLog {
  id          String   @id @default(cuid())
  actorId     String
  actor       User     @relation("Actor", fields: [actorId], references: [id])
  action      String   // e.g. 'PAYOUT_RELEASE', 'USER_SUSPEND'
  target      String?  // e.g. 'User:abc123'
  reason      String?
  payload     Json?
  createdAt   DateTime @default(now())

  @@index([actorId, createdAt])
  @@index([target])
}

// ============================================================================
// Webhook idempotency
// ============================================================================

model WebhookEvent {
  id             String   @id @default(cuid())
  source         String   // 'portone'
  eventType      String
  externalId     String   // paymentId etc.
  eventTimestamp DateTime
  payload        Json
  signatureOk    Boolean  @default(false)
  processedAt    DateTime?
  createdAt      DateTime @default(now())

  @@unique([source, externalId, eventType, eventTimestamp])
  @@index([processedAt])
}

// ============================================================================
// v0.5 M3 — OTP Challenge (SMS/Email 백업 인증)
// ============================================================================

enum OtpKind {
  SMS
  EMAIL
}

model OtpChallenge {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind         OtpKind
  codeHash     String   // bcrypt hash of 6-digit code
  expiresAt    DateTime
  attemptCount Int      @default(0)
  usedAt       DateTime?
  createdAt    DateTime @default(now())

  @@index([userId, usedAt])
  @@index([createdAt])
}
