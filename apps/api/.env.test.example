# apps/api/.env.test — copy to .env.test and adjust as needed.
# Loaded by apps/api/test/_setup.ts before any test runs.
#
# DB: same as .env unless you want isolation. docker compose up -d postgres.
DATABASE_URL=postgresql://nuxia:nuxia@localhost:5432/nuxia?schema=public

# 32-byte hex (64 chars). Deterministic so ciHash values are reproducible across runs.
APP_ENCRYPTION_KEY=00112233445566778899aabbccddeeff00112233445566778899aabbccddeeff
APP_ENCRYPTION_SALT=nuxia-test-salt

WITHDRAW_COOLDOWN_DAYS=30
HOLD_DAYS=7

# PortOne — stubbed in tests, but the client still reads these.
PORTONE_STORE_ID=store-test
PORTONE_API_SECRET=test-secret
